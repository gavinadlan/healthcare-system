

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}


model Patient {
  id    String @id
  first_name    String
  last_name     String  
  date_of_birth   DateTime
  address    String
  phone_number  String
  email   String
  insurance_provider    String
  insurance_id    String
  insurance_name    String
}